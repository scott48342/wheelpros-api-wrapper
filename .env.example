# Wheel Pros credentials
WHEELPROS_USERNAME=
WHEELPROS_PASSWORD=

# Base URLs (defaults shown)
WHEELPROS_AUTH_BASE_URL=https://api.wheelpros.com/auth
WHEELPROS_PRODUCTS_BASE_URL=https://api.wheelpros.com/products

# Refresh early (ms)
WHEELPROS_TOKEN_SKEW_MS=60000

# Wrapper server
PORT=8787

# Optional shared key to protect your wrapper
# If set, clients must send: x-api-key: <value>
# WRAPPER_API_KEY=
